{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metasprint.dev/schemas/graph-entity.v1.json",
  "title": "GraphEntityV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "entityId",
    "entityType",
    "label",
    "sourceRefs",
    "timestamps"
  ],
  "properties": {
    "schemaVersion": { "const": "graph_entity.v1" },
    "entityId": { "type": "string", "pattern": "^[A-Za-z0-9._:-]{6,140}$" },
    "entityType": {
      "type": "string",
      "enum": [
        "trial",
        "publication",
        "intervention",
        "endpoint",
        "subgroup",
        "guideline_topic"
      ]
    },
    "label": { "type": "string", "minLength": 1, "maxLength": 400 },
    "canonicalCode": { "type": "string", "pattern": "^[A-Za-z0-9._:-]{2,120}$" },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Za-z0-9._:-]{6,120}$" }
    },
    "attributes": { "type": "object" },
    "provenanceRef": { "type": "string", "pattern": "^[A-Za-z0-9._:-]{6,120}$" },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["createdAt", "updatedAt"],
      "properties": {
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
