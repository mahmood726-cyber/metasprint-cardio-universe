{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metasprint.dev/schemas/graph-dataset.v1.json",
  "title": "GraphDatasetV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "datasetId",
    "generatedAt",
    "snapshotId",
    "entities",
    "edges"
  ],
  "properties": {
    "schemaVersion": { "const": "graph_dataset.v1" },
    "datasetId": { "type": "string", "pattern": "^[A-Za-z0-9._:-]{6,140}$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "snapshotId": { "type": "string", "pattern": "^[A-Za-z0-9._:-]{6,120}$" },
    "pipelineVersion": { "type": "string", "minLength": 1, "maxLength": 80 },
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "https://metasprint.dev/schemas/graph-entity.v1.json" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "https://metasprint.dev/schemas/graph-edge.v1.json" }
    },
    "metadata": { "type": "object" }
  }
}
