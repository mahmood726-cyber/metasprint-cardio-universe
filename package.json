{
  "name": "metasprint-cardio-universe",
  "version": "0.1.0",
  "private": true,
  "description": "Spin-off project for MetaSprint Universe/Discovery module",
  "type": "module",
  "scripts": {
    "test": "node --test",
    "extract:phase0": "powershell -ExecutionPolicy Bypass -File scripts/extract-phase0.ps1",
    "ops:refresh-health": "node scripts/operations/compute-refresh-health.mjs",
    "ux:task-timing": "node scripts/operations/compute-discovery-workflow-timing.mjs",
    "ops:baseline": "npm run ops:refresh-health && npm run ux:task-timing && node scripts/operations/generate-week1-baseline.mjs",
    "ops:resilience-check": "node scripts/operations/validate-source-resilience.mjs",
    "ops:runtime-slo": "node scripts/operations/check-runtime-slo.mjs --policy reports/ops/packs/runtime_slo_policy.v1.json",
    "ops:runtime-slo:enforce": "node scripts/operations/check-runtime-slo.mjs --policy reports/ops/packs/runtime_slo_policy.v1.json --enforce",
    "ops:doc-sync": "node scripts/operations/verify-release-doc-sync.mjs --manifest docs/operations/RELEASE_DOC_SYNC.v1.json",
    "ops:doc-sync:enforce": "node scripts/operations/verify-release-doc-sync.mjs --manifest docs/operations/RELEASE_DOC_SYNC.v1.json --enforce",
    "ops:quarterly-drill": "node scripts/operations/run-quarterly-ops-drill.mjs",
    "editorial:lancet-readiness": "node scripts/editorial/build-lancet-readiness-pack.mjs",
    "verify:lancet": "npm run verify:release-gates && npm run verify:stats-advanced && npm run dedup:identity:multisource && npm run benchmark:ingestion-live && npm run benchmark:ranking && node scripts/editorial/build-lancet-readiness-pack.mjs --enforce",
    "benchmark:ingestion-live": "node scripts/benchmarks/run-live-ingestion-benchmark.mjs",
    "benchmark:ranking": "node scripts/benchmarks/compute-ranking-benchmark.mjs",
    "benchmark:dedup-identity": "node scripts/benchmarks/compute-dedup-identity-benchmark.mjs",
    "benchmark:pairwise-v2": "node scripts/benchmarks/compute-pairwise-v2-benchmark.mjs",
    "benchmark:bias-sensitivity": "node scripts/benchmarks/compute-bias-sensitivity-suite.mjs",
    "benchmark:network-v1": "node scripts/benchmarks/compute-network-benchmark.mjs",
    "benchmark:certainty-crosswalk:build": "node scripts/benchmarks/build-certainty-crosswalk-live-pack.mjs",
    "benchmark:certainty-crosswalk": "npm run benchmark:certainty-crosswalk:build && node scripts/benchmarks/compute-certainty-crosswalk-benchmark.mjs --fixture reports/benchmarks/packs/v2/certainty_crosswalk_live.v1.json --require-live",
    "benchmark:rct-bridge": "node scripts/benchmarks/build-rct-extractor-bridge.mjs",
    "ops:living-drift": "node scripts/operations/compute-living-drift.mjs --threshold-pack reports/ops/packs/living_drift_thresholds.v1.json",
    "ops:living-drift:enforce": "node scripts/operations/compute-living-drift.mjs --threshold-pack reports/ops/packs/living_drift_thresholds.v1.json --enforce",
    "verify:stats-advanced": "npm run benchmark:pairwise-v2 && npm run benchmark:bias-sensitivity && npm run benchmark:network-v1 && npm run benchmark:certainty-crosswalk && npm run ops:living-drift:enforce",
    "validate:fixtures": "node scripts/validate-fixtures.mjs",
    "validate:graph-suite": "node scripts/contracts/validate-graph-suite.mjs",
    "validate:ontology": "node scripts/ontology/validate-ontology-coverage.mjs",
    "test:ontology-mappings": "node scripts/ontology/verify-ontology-mappings.mjs",
    "review:summary": "node scripts/review/compute-adoption-summary.mjs",
    "review:new-cycle": "powershell -ExecutionPolicy Bypass -File scripts/review/new-cycle.ps1",
    "review:dashboard-data": "node scripts/review/build-dashboard-data.mjs",
    "security:harden-discover-markup": "node scripts/security/harden-discover-markup.mjs",
    "security:audit-inline": "node scripts/security/audit-inline-handlers.mjs public src extracts/hardened",
    "dedup:identity": "node scripts/engine/run-identity-dedup.mjs --sources sample --strict-integrity",
    "dedup:identity:synthetic": "node scripts/engine/run-identity-dedup.mjs --sources sample --synthetic --strict-integrity",
    "dedup:identity:multisource": "node scripts/engine/run-identity-dedup.mjs --sources sample,ctgov,pubmed,openalex,europepmc --limit 25 --review-min 0.65 --strict-sources --strict-integrity",
    "dedup:apply-overrides": "node scripts/engine/apply-override-decisions.mjs",
    "verify:phase1": "npm run validate:fixtures && npm run validate:graph-suite && npm run validate:ontology && npm run test:ontology-mappings && npm run benchmark:ranking && npm run benchmark:dedup-identity && npm run security:harden-discover-markup && npm run security:audit-inline && npm run review:dashboard-data && npm run dedup:identity",
    "verify:release-gates": "node scripts/ci/verify-release-gates.mjs"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
